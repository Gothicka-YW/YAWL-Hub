{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "Link YAWL Supabase Project",
			"type": "process",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				".\\scripts\\link-supabase-project.ps1",
				"-DatabasePassword",
				"${input:yawlSupabaseDbPassword}"
			],
			"isBackground": false,
			"group": "build"
		},
		{
			"label": "Run YAWL Hub",
			"type": "shell",
			"command": "py",
			"args": [
				"-m",
				"http.server",
				"5500"
			],
			"isBackground": true,
			"group": "build"
		},
		{
			"label": "Apply YAWL Events SQL",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				".\\scripts\\apply-supabase-sql.ps1",
				"-Files",
				"supabase\\08_events_calendar.sql",
				"supabase\\10_event_type_customization.sql"
			],
			"isBackground": false,
			"group": "build"
		},
		{
			"label": "Apply YAWL Wishlist SQL",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				".\\scripts\\apply-supabase-sql.ps1",
				"-Files",
				"supabase\\11_weekly_wishlists.sql"
			],
			"isBackground": false,
			"group": "build"
		},
		{
			"label": "Apply YAWL Live Launch SQL",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				".\\scripts\\apply-supabase-sql.ps1",
				"-Files",
				"supabase\\14_invite_code_account_claims.sql",
				"supabase\\migrations\\20260512000100_self_owned_posting.sql"
			],
			"isBackground": false,
			"group": "build"
		},
		{
			"label": "Apply YAWL SQL File(s)",
			"type": "shell",
			"command": "powershell",
			"args": [
				"-NoProfile",
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				".\\scripts\\apply-supabase-sql.ps1",
				"-Files",
				"${input:yawlSupabaseSqlFiles}"
			],
			"isBackground": false,
			"group": "build"
		}
	],
	"inputs": [
		{
			"id": "yawlSupabaseDbPassword",
			"type": "promptString",
			"description": "Supabase database password for project link",
			"password": true
		},
		{
			"id": "yawlSupabaseSqlFiles",
			"type": "promptString",
			"description": "Supabase SQL file path(s), separated by commas or semicolons",
			"default": "supabase\\13_wishlist_image_uploads_and_comments.sql"
		}
	]
}