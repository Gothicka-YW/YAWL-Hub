function bootApp() {
  try {
    render();
  } catch (error) {
    renderFatalBootstrapError(error);
    return;
  }

  void loadLiveMembers().catch(renderFatalBootstrapError);
  void loadLiveEvents().catch(renderFatalBootstrapError);
  void loadLiveWishlists().catch(renderFatalBootstrapError);
  void initializeAdminSession().catch(renderFatalBootstrapError);
}

function renderFatalBootstrapError(error) {
  const normalizedError = error instanceof Error ? error : new Error(cleanText(error) || 'Unknown startup error');
  const errorSummary = `${normalizedError.name}: ${normalizedError.message}`;
  const markup = `
    <section class="panel-grid" style="padding: 2rem; min-height: 100vh; align-content: start;">
      <article class="panel panel--announcement panel--span-full">
        <p class="eyebrow">Startup Error</p>
        <h3>YAWL Hub could not finish loading</h3>
        <p class="panel-lead">${escapeHtml(errorSummary)}</p>
      </article>
    </section>
  `;

  if (app) {
    app.innerHTML = markup;
  } else {
    document.body.innerHTML = markup;
  }

  console.error('YAWL Hub bootstrap error', normalizedError);
}

